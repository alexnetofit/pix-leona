# Configurações de API - NÃO COMMITAR O ARQUIVO .env REAL!

# Chave secreta da Stripe (começa com sk_)
STRIPE_SECRET=sk_live_sua_chave_aqui

# Chave de API do AbacatePay v1 (usada para criar PIX e verificar status)
ABACATEPAY_KEY=abc_prod_sua_chave_v1_aqui

# Chave de API do AbacatePay v2 (usada para buscar checkouts por email/CPF)
ABACATEPAY_KEY_V2=abc_prod_sua_chave_v2_aqui

# Token da Guru (User Token para API v2 - busca assinaturas, contatos, transações)
GURU_TOKEN=seu_user_token_guru_aqui

# Token de integração do Leona (INTEGRATION_BILLING_BEARER_TOKEN - busca billing profile)
LEONA_BILLING_TOKEN=seu_token_leona_aqui

# Chave de API da Paddle (Bearer token para API REST)
PADDLE_API_KEY=sua_chave_paddle_aqui

# Client token publico Paddle (usado pelo Paddle.js no front)
PADDLE_CLIENT_TOKEN=live_xxxx
# Ambiente Paddle (live ou sandbox)
PADDLE_ENVIRONMENT=production
# Webhook secret HMAC pra validar payloads do Paddle
PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxx
# Price ID do plano Starter (usado em renovacoes/upgrades)
PADDLE_STARTER_PRICE_ID=pri_xxx

# === CHAT IA DE SUPORTE (/chat) ===
# Chave da OpenAI (sk-...)
OPENAI_API_KEY=sk-xxx
# Modelo OpenAI usado pelo chat de suporte
OPENAI_MODEL=gpt-5.4-mini
# Token de acesso ao /chat e a pagina /suporte (qualquer string aleatoria, mais segura == melhor)
SUPPORT_CHAT_TOKEN=cole_aqui_um_token_aleatorio_longo

# === AUTH / CORS DOS ENDPOINTS api/* ===
# Token admin do portal interno (login em /portal). Tambem usado como Bearer
# em endpoints de mutacao (update-subscription, simulate-upgrade, abacatepay-refund).
TOKEN_ADMIN=cole_aqui_um_token_admin_aleatorio_longo

# Whitelist de origins permitidos (separados por virgula). Se vazio,
# o CORS volta a ser '*' (compativel com setup antigo). Em producao,
# liste apenas os dominios reais do front:
#   CORS_ALLOWED_ORIGINS=https://client.leonaflow.com,https://gerador-pix-leona.vercel.app
CORS_ALLOWED_ORIGINS=

# Modo de enforcement da auth admin nos endpoints de mutacao:
#   warn  -> so loga falhas (default — rollout seguro)
#   deny  -> rejeita com 401 quem nao mandar Authorization: Bearer <TOKEN_ADMIN>
# Comece em warn, monitore os logs por 1-2 dias, depois mude pra deny.
AUTH_ENFORCEMENT=warn

# === FILA DE APROVACAO /suporte e /admin ===
# Persistencia da fila de cancelamentos/reembolsos pendentes. Usa o Supabase
# do projeto "Afiliados Leona". A tabela support_actions ja existe la
# (criada via MCP). Esses 2 valores ficam em Supabase Dashboard >
# Settings > API.
SUPABASE_URL=https://teklbteabwcgceemvdhd.supabase.co

# IMPORTANTE: usar a service_role key (NAO a anon). RLS esta habilitada
# na tabela sem policies, entao so service_role consegue ler/escrever.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key_aqui...
