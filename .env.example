# Configurações de API - NÃO COMMITAR O ARQUIVO .env REAL!

# Chave secreta da Stripe (começa com sk_)
STRIPE_SECRET=sk_live_sua_chave_aqui

# Chave de API do AbacatePay v1 (usada para criar PIX e verificar status)
ABACATEPAY_KEY=abc_prod_sua_chave_v1_aqui

# Chave de API do AbacatePay v2 (usada para buscar checkouts por email/CPF)
ABACATEPAY_KEY_V2=abc_prod_sua_chave_v2_aqui
